generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE: Organization & Users
// ============================================

model Organization {
  id                  String   @id @default(cuid())
  name                String
  abn                 String?
  address             String?
  city                String?
  state               String?
  postcode            String?
  country             String   @default("Australia")
  financialYearEnd    Int      @default(6)
  baseCurrency        String   @default("AUD")
  aggregatedTurnover  Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  users               User[]
  accounts            Account[]
  contacts            Contact[]
  journalEntries      JournalEntry[]
  invoices            Invoice[]
  bills               Bill[]
  bankTransactions    BankTransaction[]
  taxRates            TaxRate[]
  rdProjects          RdProject[]
  cloudProviders      CloudProvider[]
  grants              Grant[]
  scenarios           Scenario[]
  auditLogs           AuditLog[]
  rdAdviceItems       RdAdviceItem[]
  rdPipelineStages    RdPipelineStage[]
  dataRoomTokens      DataRoomToken[]
  carbonEntries       CarbonEntry[]
  currencies          Currency[]
  recurringInvoices   RecurringInvoice[]
  payments            Payment[]
  expenseClaims       ExpenseClaim[]
  basReturns          BASReturn[]
  bankRules           BankRule[]
  creditNotes         CreditNote[]
  budgets             Budget[]
  webhooks            Webhook[]
  integrations        Integration[]
  purchaseOrders      PurchaseOrder[]
  knowledgeBase       KnowledgeBase[]
  contactTags         ContactTag[]
  employees           Employee[]
  payRuns             PayRun[]
  payslips            Payslip[]
  leaveRequests       LeaveRequest[]
  taxMinimisationStrategies TaxMinimisationStrategy[]
  novatedLeases       NovatedLease[]
  fbtRecords          FBTRecord[]
  payrollTaxSummaries PayrollTaxSummary[]
  fixedAssets         FixedAsset[]
  approvalWorkflows   ApprovalWorkflow[]
  approvalRequests    ApprovalRequest[]
  exchangeRates       ExchangeRate[]
  fxGainLosses        FxGainLoss[]
  inventoryItems      InventoryItem[]
  inventoryMovements  InventoryMovement[]
  stockTakes          StockTake[]
  projects            Project[]
  timeEntries         TimeEntry[]
  projectExpenses     ProjectExpense[]
  documents           Document[]
  bankFeeds           BankFeed[]
  migrationJobs       MigrationJob[]
  projectRequirements    ProjectRequirement[]
  marketplaceListings    MarketplaceListing[]
  marketplaceContracts   MarketplaceContract[]
  contractInvoices       ContractInvoice[]
  providerReviews        ProviderReview[]
  quarterlyFinancing     QuarterlyFinancingRequest[]
  quotes                 Quote[]
  lockedPeriods          LockedPeriod[]
  yearEndCloses          YearEndClose[]
  recurringBills         RecurringBill[]
  loans                  Loan[]
  dividends              Dividend[]
  costCenters            CostCenter[]
  paymentReminders       PaymentReminder[]
  complianceDeadlines    ComplianceDeadline[]
  customerPortalTokens   CustomerPortalToken[]
  onlinePayments         OnlinePayment[]
  reportTemplates        ReportTemplate[]
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  passwordHash   String
  role           String   @default("Viewer")
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id])
  rdTimeEntries  RdTimeEntry[]
  auditLogs      AuditLog[]
  expenseClaims  ExpenseClaim[]
  favorites      UserFavorite[]
  knowledgeBase  KnowledgeBase[]
  employees      Employee[]
  processedPayRuns PayRun[]
  approvedLeaveRequests LeaveRequest[]
  approvalSteps     ApprovalStep[]
  approvalRequests  ApprovalRequest[]
  approvalActions   ApprovalAction[]
  managedProjects      Project[]       @relation("ProjectManager")
  assignedTasks        ProjectTask[]   @relation("TaskAssignee")
  projectTimeEntries   TimeEntry[]     @relation("TimeEntryUser")
  approvedTimeEntries  TimeEntry[]     @relation("TimeEntryApprover")
  approvedProjectExpenses ProjectExpense[] @relation("ProjectExpenseApprover")
  completedStockTakes  StockTake[]     @relation("StockTakeCompletedBy")
  uploadedDocuments    Document[]      @relation("DocumentUploader")
  startedMigrationJobs   MigrationJob[]  @relation("MigrationJobStartedBy")
  approvedMigrationJobs  MigrationJob[]  @relation("MigrationJobApprovedBy")
  reviewedMappings       MigrationMapping[] @relation("MigrationMappingReviewer")
  reconciledMigrations   MigrationReconciliation[] @relation("MigrationReconciler")
  migrationAuditLogs     MigrationAuditLog[] @relation("MigrationAuditLogUser")
  createdRequirements    ProjectRequirement[] @relation("RequirementCreatedBy")
  approvedRequirements   ProjectRequirement[] @relation("RequirementApprovedBy")
  respondedBids          MarketplaceBid[]     @relation("BidRespondedBy")
  approvedMilestones     ContractMilestone[]  @relation("MilestoneApprovedBy")
  approvedContractInvoices ContractInvoice[]  @relation("ContractInvoiceApprovedBy")
  providerReviews        ProviderReview[]     @relation("ProviderReviewer")
  acceptedSuggestions    RequirementSuggestion[] @relation("SuggestionAcceptedBy")
  lockedPeriods          LockedPeriod[]          @relation("LockedByUser")
  yearEndCloses          YearEndClose[]          @relation("ClosedByUser")
  managedCostCenters     CostCenter[]            @relation("CostCenterManager")
  completedDeadlines     ComplianceDeadline[]    @relation("DeadlineCompletedBy")
  createdReportTemplates ReportTemplate[]        @relation("ReportTemplateCreator")
}

// ============================================
// USER: Favorites / Bookmarks
// ============================================

model UserFavorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  label     String
  path      String
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([userId, path])
}

// ============================================
// ACCOUNTING: Chart of Accounts & Ledger
// ============================================

model Account {
  id              String   @id @default(cuid())
  code            String
  name            String
  type            String
  subType         String?
  description     String?
  taxType         String?
  isSystemAccount Boolean  @default(false)
  isActive        Boolean  @default(true)
  isRdEligible    Boolean  @default(false)
  organizationId  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization   @relation(fields: [organizationId], references: [id])
  journalLines    JournalLine[]
  invoiceLines    InvoiceLine[]
  billLines       BillLine[]
  bankRules       BankRule[]
  budgetItems     BudgetItem[]
  fixedAssets      FixedAsset[]     @relation("AssetAccount")
  fixedAssetDepreciation FixedAsset[] @relation("DepreciationAccount")
  fixedAssetAccumulated  FixedAsset[] @relation("AccumulatedDepreciationAccount")
  inventoryAssetItems    InventoryItem[] @relation("InventoryAssetAccount")
  inventoryCogsItems     InventoryItem[] @relation("InventoryCOGSAccount")
  inventoryRevenueItems  InventoryItem[] @relation("InventoryRevenueAccount")
  quoteLines             QuoteLine[]
  recurringBills         RecurringBill[]
  loanLiability          Loan[]          @relation("LoanLiabilityAccount")
  loanInterestExpense    Loan[]          @relation("LoanInterestExpenseAccount")

  @@unique([code, organizationId])
}

model JournalEntry {
  id              String   @id @default(cuid())
  entryNumber     Int
  date            DateTime
  reference       String?
  narration       String
  status          String   @default("Draft")
  sourceType      String?
  sourceId        String?
  organizationId  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization  @relation(fields: [organizationId], references: [id])
  lines           JournalLine[]
  bankTransaction BankTransaction? @relation("MatchedJournal")
  depreciationSchedules DepreciationSchedule[]
  fxGainLosses    FxGainLoss[]
  migrationJournalEntries MigrationJournalEntry[]
  yearEndCloses           YearEndClose[]        @relation("RetainedEarningsEntry")
  loanPayments            LoanPayment[]
  dividends               Dividend[]
}

model JournalLine {
  id              String   @id @default(cuid())
  journalEntryId  String
  accountId       String
  description     String?
  debit           Float    @default(0)
  credit          Float    @default(0)
  taxCode         String?
  rdProjectId     String?
  rdActivityId    String?
  experimentId    String?

  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id])
  account         Account      @relation(fields: [accountId], references: [id])
  rdProject       RdProject?   @relation(fields: [rdProjectId], references: [id])
  rdActivity      RdActivity?  @relation(fields: [rdActivityId], references: [id])
  experiment      Experiment?  @relation(fields: [experimentId], references: [id])
  rdExpenses      RdExpense[]
  costCenterAllocations CostCenterAllocation[]
}

// ============================================
// ACCOUNTING: Contacts
// ============================================

model Contact {
  id              String   @id @default(cuid())
  name            String
  email           String?
  phone           String?
  abn             String?
  contactType     String   @default("Customer")
  address         String?
  city            String?
  state           String?
  postcode        String?
  isRdContractor  Boolean  @default(false)
  organizationId  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id])
  invoices        Invoice[]
  bills           Bill[]
  recurringInvoices RecurringInvoice[]
  creditNotes     CreditNote[]
  purchaseOrders  PurchaseOrder[]
  tagAssignments  ContactTagAssignment[]
  suppliedItems   InventoryItem[] @relation("InventorySupplier")
  clientProjects  Project[]       @relation("ProjectClient")
  quotes              Quote[]
  recurringBills      RecurringBill[]
  lenderLoans         Loan[]              @relation("LoanLenderContact")
  customerPortalTokens CustomerPortalToken[]
}

// ============================================
// ACCOUNTING: Invoices
// ============================================

model Invoice {
  id              String   @id @default(cuid())
  invoiceNumber   String
  contactId       String
  date            DateTime
  dueDate         DateTime
  status          String   @default("Draft")
  subtotal        Float    @default(0)
  taxTotal        Float    @default(0)
  total           Float    @default(0)
  amountDue       Float?
  notes           String?
  organizationId  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contact         Contact       @relation(fields: [contactId], references: [id])
  organization    Organization  @relation(fields: [organizationId], references: [id])
  lines           InvoiceLine[]
  payments        Payment[]
  billedTimeEntries    TimeEntry[]
  billedProjectExpenses ProjectExpense[]
  projectMilestones    ProjectMilestone[]
  contractMilestones   ContractMilestone[]
  convertedFromQuotes  Quote[]             @relation("QuoteConvertedInvoice")
  paymentReminders     PaymentReminder[]
  onlinePayments       OnlinePayment[]
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  accountId   String
  taxType     String?
  amount      Float

  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  account     Account @relation(fields: [accountId], references: [id])
}

// ============================================
// ACCOUNTING: Bills
// ============================================

model Bill {
  id              String   @id @default(cuid())
  billNumber      String
  contactId       String
  date            DateTime
  dueDate         DateTime
  status          String   @default("Draft")
  subtotal        Float    @default(0)
  taxTotal        Float    @default(0)
  total           Float    @default(0)
  amountDue       Float?
  notes           String?
  organizationId  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contact         Contact       @relation(fields: [contactId], references: [id])
  organization    Organization  @relation(fields: [organizationId], references: [id])
  lines           BillLine[]
  payments        Payment[]
}

model BillLine {
  id          String  @id @default(cuid())
  billId      String
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  accountId   String
  taxType     String?
  amount      Float

  bill        Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  account     Account @relation(fields: [accountId], references: [id])
}

// ============================================
// ACCOUNTING: Banking
// ============================================

model BankTransaction {
  id              String   @id @default(cuid())
  date            DateTime
  description     String
  amount          Float
  reference       String?
  reconciled      Boolean  @default(false)
  matchedJournalId String?  @unique
  organizationId  String
  createdAt       DateTime @default(now())

  matchedJournal  JournalEntry? @relation("MatchedJournal", fields: [matchedJournalId], references: [id])
  organization    Organization  @relation(fields: [organizationId], references: [id])
  bankFeedMatch   BankFeedTransaction?
}

model TaxRate {
  id              String   @id @default(cuid())
  name            String
  rate            Float
  taxType         String
  isDefault       Boolean  @default(false)
  organizationId  String

  organization    Organization @relation(fields: [organizationId], references: [id])
  inventoryItems  InventoryItem[]
  quoteLines      QuoteLine[]
  recurringBills  RecurringBill[]
}

// ============================================
// R&D INTELLIGENCE: Projects & Activities
// ============================================

model RdProject {
  id                      String   @id @default(cuid())
  name                    String
  description             String?
  startDate               DateTime
  endDate                 DateTime?
  status                  String   @default("Active")
  coreActivityDescription String?
  hypothesisSummary       String?
  technicalUncertainty    String?
  newKnowledgeSought      String?
  eligibilityStatus       String   @default("Pending")
  budget                  Float?
  organizationId          String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  organization            Organization          @relation(fields: [organizationId], references: [id])
  activities              RdActivity[]
  journalLines            JournalLine[]
  rdExpenses              RdExpense[]
  complianceChecklist     RdComplianceChecklist[]
  portfolioEntry          RdPortfolioEntry?
  claimDrafts             RdClaimDraft[]
  auditPacks              AuditPack[]
  carbonEntries           CarbonEntry[]
  expenseClaimItems       ExpenseClaimItem[]
  knowledgeBase           KnowledgeBase[]
  fixedAssets             FixedAsset[]
  linkedProjects          Project[]    @relation("ProjectRdProject")
  projectRequirements     ProjectRequirement[]
}

model RdActivity {
  id                   String   @id @default(cuid())
  rdProjectId          String
  name                 String
  activityType         String   @default("Core")
  hypothesis           String?
  methodology          String?
  outcome              String?
  technicalUncertainty String?
  newKnowledgeSought   String?
  status               String   @default("InProgress")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  rdProject            RdProject     @relation(fields: [rdProjectId], references: [id])
  experiments          Experiment[]
  evidence             RdEvidence[]
  timeEntries          RdTimeEntry[]
  journalLines         JournalLine[]
  rdExpenses           RdExpense[]
}

// ============================================
// R&D INTELLIGENCE: Experiments
// ============================================

model Experiment {
  id              String   @id @default(cuid())
  rdActivityId    String
  name            String
  hypothesis      String?
  status          String   @default("Planned")
  startDate       DateTime?
  endDate         DateTime?
  outcome         String?
  iterationNumber Int      @default(1)
  pipelineStageId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rdActivity      RdActivity          @relation(fields: [rdActivityId], references: [id])
  pipelineStage   RdPipelineStage?    @relation(fields: [pipelineStageId], references: [id])
  resources       ExperimentResource[]
  outcomes        ExperimentOutcome[]
  journalLines    JournalLine[]
  cloudCosts      CloudCostEntry[]
}

model ExperimentResource {
  id           String  @id @default(cuid())
  experimentId String
  resourceType String
  description  String
  cost         Float
  quantity     Float?
  unit         String?

  experiment   Experiment @relation(fields: [experimentId], references: [id])
}

model ExperimentOutcome {
  id           String   @id @default(cuid())
  experimentId String
  outcomeType  String
  notes        String?
  metricsJson  String?
  recordedAt   DateTime @default(now())

  experiment   Experiment @relation(fields: [experimentId], references: [id])
}

// ============================================
// R&D INTELLIGENCE: Evidence & Time Tracking
// ============================================

model RdEvidence {
  id           String   @id @default(cuid())
  rdActivityId String
  fileName     String
  fileType     String
  filePath     String
  fileSize     Int?
  description  String?
  category     String   @default("Other")
  uploadedAt   DateTime @default(now())

  rdActivity   RdActivity @relation(fields: [rdActivityId], references: [id])
}

model RdTimeEntry {
  id           String   @id @default(cuid())
  userId       String
  rdActivityId String
  date         DateTime
  hours        Float
  description  String?
  hourlyRate   Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User       @relation(fields: [userId], references: [id])
  rdActivity   RdActivity @relation(fields: [rdActivityId], references: [id])
}

model RdExpense {
  id             String  @id @default(cuid())
  journalLineId  String
  rdProjectId    String
  rdActivityId   String?
  category       String
  classification String  @default("NeedsReview")

  journalLine    JournalLine @relation(fields: [journalLineId], references: [id])
  rdProject      RdProject   @relation(fields: [rdProjectId], references: [id])
  rdActivity     RdActivity? @relation(fields: [rdActivityId], references: [id])
}

// ============================================
// AI INFRASTRUCTURE: Cloud Costs
// ============================================

model CloudProvider {
  id              String   @id @default(cuid())
  name            String
  displayName     String
  enabled         Boolean  @default(true)
  organizationId  String
  createdAt       DateTime @default(now())

  organization    Organization   @relation(fields: [organizationId], references: [id])
  costEntries     CloudCostEntry[]
  computeUsage    ComputeUsage[]
  tokenUsage      TokenUsage[]
}

model CloudCostEntry {
  id           String   @id @default(cuid())
  providerId   String
  date         DateTime
  service      String
  description  String?
  amount       Float
  currency     String   @default("AUD")
  tags         String?
  projectId    String?
  experimentId String?
  createdAt    DateTime @default(now())

  provider     CloudProvider @relation(fields: [providerId], references: [id])
  experiment   Experiment?   @relation(fields: [experimentId], references: [id])
}

model ComputeUsage {
  id           String   @id @default(cuid())
  providerId   String
  date         DateTime
  instanceType String
  hours        Float
  cost         Float
  experimentId String?
  modelName    String?

  provider     CloudProvider @relation(fields: [providerId], references: [id])
}

model TokenUsage {
  id           String   @id @default(cuid())
  providerId   String
  date         DateTime
  model        String
  inputTokens  Int
  outputTokens Int
  cost         Float
  experimentId String?

  provider     CloudProvider @relation(fields: [providerId], references: [id])
}

// ============================================
// R&D PIPELINE & PORTFOLIO
// ============================================

model RdPipelineStage {
  id              String   @id @default(cuid())
  name            String
  stageOrder      Int
  description     String?
  organizationId  String

  organization    Organization @relation(fields: [organizationId], references: [id])
  experiments     Experiment[]
}

model RdPortfolioEntry {
  id                   String  @id @default(cuid())
  rdProjectId          String  @unique
  probabilityOfSuccess Float?
  expectedROI          Float?
  capitalAllocated     Float?
  actualSpend          Float?
  status               String  @default("Active")

  rdProject            RdProject @relation(fields: [rdProjectId], references: [id])
}

// ============================================
// GRANTS & INCENTIVES
// ============================================

model Grant {
  id                  String   @id @default(cuid())
  name                String
  provider            String
  status              String   @default("Discovered")
  amount              Float?
  applicationDeadline DateTime?
  description         String?
  organizationId      String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization        Organization    @relation(fields: [organizationId], references: [id])
  milestones          GrantMilestone[]
}

model GrantMilestone {
  id          String   @id @default(cuid())
  grantId     String
  title       String
  dueDate     DateTime?
  completed   Boolean  @default(false)
  spendToDate Float?
  evidence    String?
  createdAt   DateTime @default(now())

  grant       Grant @relation(fields: [grantId], references: [id])
}

model RdClaimDraft {
  id                       String   @id @default(cuid())
  rdProjectId              String?
  financialYear            String
  totalEligibleExpenditure Float
  offsetRate               Float
  estimatedOffset          Float
  status                   String   @default("Draft")
  breakdownJson            String?
  generatedAt              DateTime @default(now())

  rdProject                RdProject? @relation(fields: [rdProjectId], references: [id])
}

// ============================================
// COMPLIANCE & AUDIT
// ============================================

model AuditLog {
  id             String   @id @default(cuid())
  userId         String?
  action         String
  entityType     String
  entityId       String?
  details        String?
  organizationId String
  timestamp      DateTime @default(now())

  user           User?        @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model RdComplianceChecklist {
  id          String   @id @default(cuid())
  rdProjectId String
  item        String
  category    String
  completed   Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rdProject   RdProject @relation(fields: [rdProjectId], references: [id])
}

model AuditPack {
  id              String   @id @default(cuid())
  rdProjectId     String
  financialYear   String
  status          String   @default("Generated")
  filePath        String?
  generatedAt     DateTime @default(now())

  rdProject       RdProject @relation(fields: [rdProjectId], references: [id])
}

// ============================================
// DATA ROOM: Share Tokens
// ============================================

model DataRoomToken {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  token          String       @unique
  name           String
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  lastAccessedAt DateTime?
}

// ============================================
// SCENARIO SIMULATION
// ============================================

model Scenario {
  id              String   @id @default(cuid())
  name            String
  description     String?
  baselineJson    String?
  variablesJson   String?
  resultsJson     String?
  organizationId  String
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])
}

// ============================================
// R&D ADVICE
// ============================================

model RdAdviceItem {
  id              String   @id @default(cuid())
  title           String
  content         String
  category        String
  priority        Int      @default(0)
  applicableWhen  String?
  organizationId  String?

  organization    Organization? @relation(fields: [organizationId], references: [id])
}

// ============================================
// SUSTAINABILITY: Carbon & Energy Accounting
// ============================================

model CarbonEntry {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  date           DateTime
  category       String       // Scope1, Scope2, Scope3
  source         String       // e.g., "Electricity", "GPU Compute", "Air Travel", "Cloud Data Center"
  quantity       Float        // e.g., kWh, km, hours
  unit           String       // kWh, km, GPU-hours, etc.
  emissionFactor Float        // kg CO2e per unit
  totalEmissions Float        // quantity * emissionFactor (kg CO2e)
  cost           Float?       // associated cost if any
  notes          String?
  projectId      String?      // optional link to R&D project
  project        RdProject?   @relation(fields: [projectId], references: [id])
  createdAt      DateTime     @default(now())
}

// ============================================
// MULTI-CURRENCY
// ============================================

model Currency {
  id             String       @id @default(cuid())
  code           String       // AUD, USD, GBP, EUR, etc.
  name           String       // Australian Dollar
  symbol         String       // $, £, €
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  isBase         Boolean      @default(false)
  exchangeRate   Float        @default(1.0) // rate relative to base currency
  updatedAt      DateTime     @updatedAt
  createdAt      DateTime     @default(now())

  @@unique([organizationId, code])
}

// ============================================
// RECURRING INVOICES
// ============================================

model RecurringInvoice {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  contactId      String
  contact        Contact      @relation(fields: [contactId], references: [id])
  frequency      String       // weekly, fortnightly, monthly, quarterly, annually
  nextDate       DateTime
  endDate        DateTime?
  dayOfMonth     Int?         // for monthly: which day
  isActive       Boolean      @default(true)
  templateData   String       // JSON: line items, notes, tax settings
  lastGenerated  DateTime?
  invoiceCount   Int          @default(0)
  createdAt      DateTime     @default(now())
}

// ============================================
// PAYMENTS
// ============================================

model Payment {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  type           String       // received (from customer) or made (to supplier)
  amount         Float
  date           DateTime
  reference      String?
  method         String       // bank_transfer, cash, credit_card, cheque
  invoiceId      String?
  invoice        Invoice?     @relation(fields: [invoiceId], references: [id])
  billId         String?
  bill           Bill?        @relation(fields: [billId], references: [id])
  journalEntryId String?
  notes          String?
  createdAt      DateTime     @default(now())
  contractMilestones ContractMilestone[]
}

// ============================================
// EXPENSE CLAIMS
// ============================================

model ExpenseClaim {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id])
  userId         String
  user           User               @relation(fields: [userId], references: [id])
  claimNumber    String
  date           DateTime
  status         String             @default("Draft") // Draft, Submitted, Approved, Paid, Rejected
  totalAmount    Float              @default(0)
  notes          String?
  items          ExpenseClaimItem[]
  createdAt      DateTime           @default(now())
}

model ExpenseClaimItem {
  id          String        @id @default(cuid())
  claimId     String
  claim       ExpenseClaim  @relation(fields: [claimId], references: [id])
  date        DateTime
  description String
  category    String        // travel, meals, supplies, software, equipment, other
  amount      Float
  taxAmount   Float         @default(0)
  accountId   String?
  receiptPath String?       // uploaded receipt file
  rdProjectId String?       // optional R&D allocation
  rdProject   RdProject?    @relation(fields: [rdProjectId], references: [id])
}

// ============================================
// TAX: BAS Returns
// ============================================

model BASReturn {
  id                     String       @id @default(cuid())
  organizationId         String
  organization           Organization @relation(fields: [organizationId], references: [id])
  period                 String       // e.g., "Q1 2025-26", "Jan 2026"
  startDate              DateTime
  endDate                DateTime
  status                 String       @default("Draft") // Draft, Lodged
  g1TotalSales           Float        @default(0)
  g2ExportSales          Float        @default(0)
  g3GstFreeSales         Float        @default(0)
  g10CapitalPurchases    Float        @default(0)
  g11NonCapitalPurchases Float        @default(0)
  gstOnSales             Float        @default(0) // 1A
  gstOnPurchases         Float        @default(0) // 1B
  netGst                 Float        @default(0)
  w1TotalWages           Float        @default(0)
  w2Withheld             Float        @default(0)
  lodgedAt               DateTime?
  createdAt              DateTime     @default(now())
}

// ============================================
// BANKING: Auto-Categorization Rules
// ============================================

model BankRule {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  matchField     String       // description, amount, reference
  matchType      String       // contains, exact, startsWith, regex
  matchValue     String
  accountId      String       // account to categorize to
  account        Account      @relation(fields: [accountId], references: [id])
  contactId      String?      // optional contact to assign
  taxType        String?      // GST, GST Free, etc.
  rdProjectId    String?      // optional R&D project tagging
  isActive       Boolean      @default(true)
  priority       Int          @default(0)
  createdAt      DateTime     @default(now())
}

// ============================================
// ACCOUNTING: Credit Notes
// ============================================

model CreditNote {
  id               String           @id @default(cuid())
  organizationId   String
  organization     Organization     @relation(fields: [organizationId], references: [id])
  creditNoteNumber String
  contactId        String
  contact          Contact          @relation(fields: [contactId], references: [id])
  invoiceId        String?          // optional linked invoice
  date             DateTime
  status           String           @default("Draft") // Draft, Approved, Applied, Void
  subtotal         Float            @default(0)
  taxTotal         Float            @default(0)
  total            Float            @default(0)
  reason           String?
  notes            String?
  lines            CreditNoteLine[]
  createdAt        DateTime         @default(now())
}

model CreditNoteLine {
  id           String     @id @default(cuid())
  creditNoteId String
  creditNote   CreditNote @relation(fields: [creditNoteId], references: [id])
  description  String
  quantity     Float      @default(1)
  unitPrice    Float
  accountId    String
  taxType      String     @default("GST")
  amount       Float
  taxAmount    Float      @default(0)
}

// ============================================
// BUDGETING & FORECASTING
// ============================================

model Budget {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String       // e.g., "FY 2025-26 Operating Budget"
  financialYear  String       // e.g., "2025-26"
  status         String       @default("Draft") // Draft, Active, Closed
  items          BudgetItem[]
  createdAt      DateTime     @default(now())
}

model BudgetItem {
  id        String  @id @default(cuid())
  budgetId  String
  budget    Budget  @relation(fields: [budgetId], references: [id])
  accountId String
  account   Account @relation(fields: [accountId], references: [id])
  jan       Float   @default(0)
  feb       Float   @default(0)
  mar       Float   @default(0)
  apr       Float   @default(0)
  may       Float   @default(0)
  jun       Float   @default(0)
  jul       Float   @default(0)
  aug       Float   @default(0)
  sep       Float   @default(0)
  oct       Float   @default(0)
  nov       Float   @default(0)
  dec       Float   @default(0)
  total     Float   @default(0)
  notes     String?
}

// ============================================
// WEBHOOKS & INTEGRATIONS
// ============================================

model Webhook {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  name            String
  url             String
  events          String       // comma-separated: invoice.created, bill.created, payment.received, etc.
  secret          String?      // for HMAC-SHA256 signature verification
  isActive        Boolean      @default(true)
  lastTriggeredAt DateTime?
  failCount       Int          @default(0)
  createdAt       DateTime     @default(now())
}

model Integration {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  type            String       // xero, myob, stripe, slack, github
  name            String
  config          String       // JSON config
  isActive        Boolean      @default(true)
  lastSyncAt      DateTime?
  createdAt       DateTime     @default(now())
}

// ============================================
// CONTACTS: Tags & Groups
// ============================================

model ContactTag {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  color          String       @default("#6366f1")
  contacts       ContactTagAssignment[]

  @@unique([organizationId, name])
}

model ContactTagAssignment {
  id        String     @id @default(cuid())
  contactId String
  contact   Contact    @relation(fields: [contactId], references: [id])
  tagId     String
  tag       ContactTag @relation(fields: [tagId], references: [id])

  @@unique([contactId, tagId])
}

// ============================================
// PURCHASE ORDERS
// ============================================

model PurchaseOrder {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  poNumber       String
  contactId      String
  contact        Contact      @relation(fields: [contactId], references: [id])
  date           DateTime
  deliveryDate   DateTime?
  status         String       @default("Draft")
  subtotal       Float        @default(0)
  taxTotal       Float        @default(0)
  total          Float        @default(0)
  notes          String?
  lines          PurchaseOrderLine[]
  createdAt      DateTime     @default(now())
}

model PurchaseOrderLine {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  description     String
  quantity        Float         @default(1)
  unitPrice       Float
  accountId       String
  taxType         String        @default("GST")
  amount          Float
  taxAmount       Float         @default(0)
}

// ============================================
// R&D KNOWLEDGE BASE
// ============================================

model KnowledgeBase {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  title          String
  content        String
  category       String
  tags           String
  projectId      String?
  project        RdProject?   @relation(fields: [projectId], references: [id])
  authorId       String
  author         User         @relation(fields: [authorId], references: [id])
  isPublished    Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ============================================
// PAYROLL MODULE
// ============================================

model Employee {
  id                    String   @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id])
  userId                String?
  user                  User?    @relation(fields: [userId], references: [id])
  firstName             String
  lastName              String
  email                 String
  dateOfBirth           DateTime?
  startDate             DateTime
  endDate               DateTime?
  employmentType        String   @default("FullTime") // FullTime, PartTime, Casual, Contractor
  taxFileNumber         String?  // encrypted/masked
  residencyStatus       String   @default("Resident") // Resident, NonResident, WorkingHoliday
  taxFreeThreshold      Boolean  @default(true)
  helpDebt              Boolean  @default(false) // HECS/HELP
  sfssDebt              Boolean  @default(false)
  medicareLevyExemption String   @default("None") // None, Full, Half
  superFundName         String?
  superMemberNumber     String?
  superRate             Float    @default(11.5)
  bankBSB               String?
  bankAccountNumber     String?
  bankAccountName       String?
  annualSalary          Float?
  hourlyRate            Float?
  payFrequency          String   @default("Monthly") // Weekly, Fortnightly, Monthly
  leaveBalanceAnnual    Float    @default(0)
  leaveBalanceSick      Float    @default(0)
  leaveBalancePersonal  Float    @default(0)
  notes                 String?
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  payslips              Payslip[]
  leaveRequests         LeaveRequest[]
  novatedLeases         NovatedLease[]
  fbtRecords            FBTRecord[]
  payrollTaxSummaries   PayrollTaxSummary[]

  @@index([organizationId])
  @@index([organizationId, active])
  @@index([organizationId, employmentType])
}

model PayRun {
  id              String    @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  payPeriodStart  DateTime
  payPeriodEnd    DateTime
  payDate         DateTime
  status          String    @default("Draft") // Draft, Processing, Completed, Voided
  totalGross      Float     @default(0)
  totalTax        Float     @default(0)
  totalSuper      Float     @default(0)
  totalNet        Float     @default(0)
  totalDeductions Float     @default(0)
  processedAt     DateTime?
  processedById   String?
  processedBy     User?     @relation(fields: [processedById], references: [id])
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  payslips        Payslip[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, payPeriodStart, payPeriodEnd])
}

model Payslip {
  id                   String   @id @default(cuid())
  payRunId             String
  payRun               PayRun   @relation(fields: [payRunId], references: [id])
  employeeId           String
  employee             Employee @relation(fields: [employeeId], references: [id])
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id])
  payPeriodStart       DateTime
  payPeriodEnd         DateTime
  payDate              DateTime
  hoursWorked          Float    @default(0)
  hourlyRate           Float    @default(0)
  grossPay             Float    @default(0)
  overtimeHours        Float    @default(0)
  overtimePay          Float    @default(0)
  allowances           Float    @default(0)
  bonuses              Float    @default(0)
  taxWithheld          Float    @default(0)
  medicareLevyAmount   Float    @default(0)
  helpRepayment        Float    @default(0)
  sfssRepayment        Float    @default(0)
  superContribution    Float    @default(0)
  superSalarySacrifice Float    @default(0)
  preTaxDeductions     Float    @default(0)
  postTaxDeductions    Float    @default(0)
  netPay               Float    @default(0)
  yearToDateGross      Float    @default(0)
  yearToDateTax        Float    @default(0)
  yearToDateSuper      Float    @default(0)
  status               String   @default("Draft") // Draft, Approved, Paid, Voided
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  earnings             PayslipEarning[]
  deductions           PayslipDeduction[]
  leave                PayslipLeave[]

  @@index([organizationId])
  @@index([organizationId, employeeId])
  @@index([payRunId])
  @@index([employeeId, payPeriodStart])
}

model PayslipEarning {
  id          String  @id @default(cuid())
  payslipId   String
  payslip     Payslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  type        String  // Ordinary, Overtime, Bonus, Commission, Allowance, BackPay, TerminationPay, LeaveLoading
  description String
  hours       Float?
  rate        Float?
  amount      Float

  @@index([payslipId])
}

model PayslipDeduction {
  id          String  @id @default(cuid())
  payslipId   String
  payslip     Payslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  type        String  // PreTax, PostTax
  category    String  // SalarySacrifice, UnionFees, WorkplaceGiving, ChildSupport, Other
  description String
  amount      Float

  @@index([payslipId])
}

model PayslipLeave {
  id           String  @id @default(cuid())
  payslipId    String
  payslip      Payslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  type         String  // Annual, Sick, Personal, LongService, Parental, Compassionate, Unpaid
  hoursAccrued Float   @default(0)
  hoursTaken   Float   @default(0)
  balance      Float   @default(0)

  @@index([payslipId])
}

model LeaveRequest {
  id             String    @id @default(cuid())
  employeeId     String
  employee       Employee  @relation(fields: [employeeId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  type           String    // Annual, Sick, Personal, LongService, Parental, Compassionate, Unpaid
  startDate      DateTime
  endDate        DateTime
  hoursRequested Float
  status         String    @default("Pending") // Pending, Approved, Rejected, Cancelled
  approvedById   String?
  approvedBy     User?     @relation(fields: [approvedById], references: [id])
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
  @@index([employeeId])
  @@index([organizationId, status])
}

model TaxMinimisationStrategy {
  id              String    @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  category        String    // SalarySacrifice, NovatedLease, FBTExempt, WorkFromHome, ProfessionalDevelopment, CharitableDonation, DepreciationDeduction, RDOffset, SuperContribution, IncomeSmoothing
  title           String
  description     String?
  estimatedSaving Float?
  implemented     Boolean   @default(false)
  implementedDate DateTime?
  applicableTo    String    @default("Both") // Individual, Corporate, Both
  priority        String    @default("Medium") // High, Medium, Low
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([organizationId])
  @@index([organizationId, category])
}

model NovatedLease {
  id                 String    @id @default(cuid())
  employeeId         String
  employee           Employee  @relation(fields: [employeeId], references: [id])
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id])
  vehicleDescription String
  leaseStartDate     DateTime
  leaseEndDate       DateTime
  annualLeaseAmount  Float
  preTaxDeduction    Float
  postTaxDeduction   Float
  fbtValue           Float     @default(0)
  fbtExemptEV        Boolean   @default(false)
  runningCostsAnnual Float     @default(0)
  status             String    @default("Pending") // Active, Ended, Pending
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([organizationId])
  @@index([employeeId])
}

model FBTRecord {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  fyYear         String
  employeeId     String
  employee       Employee @relation(fields: [employeeId], references: [id])
  benefitType    String   // Vehicle, Parking, Entertainment, LivingAway, Other
  grossValue     Float    @default(0)
  exemptAmount   Float    @default(0)
  taxableValue   Float    @default(0)
  fbtRate        Float    @default(0.47)
  fbtPayable     Float    @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, fyYear])
  @@index([employeeId])
}

model PayrollTaxSummary {
  id                       String  @id @default(cuid())
  organizationId           String
  organization             Organization @relation(fields: [organizationId], references: [id])
  employeeId               String
  employee                 Employee @relation(fields: [employeeId], references: [id])
  fyYear                   String
  totalGross               Float   @default(0)
  totalTax                 Float   @default(0)
  totalSuper               Float   @default(0)
  totalAllowances          Float   @default(0)
  totalDeductions          Float   @default(0)
  totalFBT                 Float   @default(0)
  totalNovatedLease        Float   @default(0)
  reportableEmployerSuper  Float   @default(0)
  reportableFringeBenefits Float   @default(0)
  lumpSumPayments          Float   @default(0)
  terminationPayments      Float   @default(0)
  etpTaxFree               Float   @default(0)
  etpTaxable               Float   @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, fyYear])
  @@index([employeeId, fyYear])
}

// ============================================
// FIXED ASSETS & DEPRECIATION
// ============================================

model FixedAsset {
  id                           String    @id @default(cuid())
  organizationId               String
  organization                 Organization @relation(fields: [organizationId], references: [id])
  assetNumber                  String
  name                         String
  description                  String?
  category                     String    // Plant, Equipment, Vehicle, Furniture, Computer, Software, Building, LandImprovements, Other
  purchaseDate                 DateTime
  purchasePrice                Float
  residualValue                Float     @default(0)
  usefulLifeYears              Float
  depreciationMethod           String    @default("StraightLine") // StraightLine, DiminishingValue, UnitsOfProduction
  accountId                    String
  account                      Account   @relation("AssetAccount", fields: [accountId], references: [id])
  depreciationAccountId        String
  depreciationAccount          Account   @relation("DepreciationAccount", fields: [depreciationAccountId], references: [id])
  accumulatedDepreciationAccountId String
  accumulatedDepreciationAccount   Account @relation("AccumulatedDepreciationAccount", fields: [accumulatedDepreciationAccountId], references: [id])
  currentBookValue             Float
  status                       String    @default("Active") // Active, Disposed, FullyDepreciated, WrittenOff
  disposalDate                 DateTime?
  disposalPrice                Float?
  disposalMethod               String?   // Sale, Scrapped, TradeIn
  location                     String?
  serialNumber                 String?
  supplier                     String?
  warrantyExpiry               DateTime?
  isRdAsset                    Boolean   @default(false)
  rdProjectId                  String?
  rdProject                    RdProject? @relation(fields: [rdProjectId], references: [id])
  notes                        String?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  depreciationSchedules        DepreciationSchedule[]

  @@unique([organizationId, assetNumber])
  @@index([organizationId])
  @@index([organizationId, status])
}

model DepreciationSchedule {
  id                     String       @id @default(cuid())
  fixedAssetId           String
  fixedAsset             FixedAsset   @relation(fields: [fixedAssetId], references: [id])
  periodStart            DateTime
  periodEnd              DateTime
  openingValue           Float
  depreciationAmount     Float
  accumulatedDepreciation Float
  closingValue           Float
  status                 String       @default("Scheduled") // Scheduled, Posted, Reversed
  journalEntryId         String?
  journalEntry           JournalEntry? @relation(fields: [journalEntryId], references: [id])
  createdAt              DateTime     @default(now())

  @@index([fixedAssetId])
}

// ============================================
// APPROVAL WORKFLOWS
// ============================================

model ApprovalWorkflow {
  id                String   @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])
  name              String
  entityType        String   // Bill, Expense, PurchaseOrder, PayRun, JournalEntry
  minAmount         Float?
  maxAmount         Float?
  requiredApprovers Int      @default(1)
  autoApproveBelow  Float?
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  steps             ApprovalStep[]
  requests          ApprovalRequest[]

  @@index([organizationId])
  @@index([organizationId, entityType])
}

model ApprovalStep {
  id           String           @id @default(cuid())
  workflowId   String
  workflow     ApprovalWorkflow @relation(fields: [workflowId], references: [id])
  stepOrder    Int
  approverId   String
  approver     User             @relation(fields: [approverId], references: [id])
  role         String           @default("Approver") // Approver, Reviewer, FinalApprover
  canDelegate  Boolean          @default(false)
  createdAt    DateTime         @default(now())

  @@index([workflowId])
}

model ApprovalRequest {
  id              String           @id @default(cuid())
  organizationId  String
  organization    Organization     @relation(fields: [organizationId], references: [id])
  workflowId      String
  workflow        ApprovalWorkflow @relation(fields: [workflowId], references: [id])
  entityType      String
  entityId        String
  requestedById   String
  requestedBy     User             @relation(fields: [requestedById], references: [id])
  currentStep     Int              @default(1)
  status          String           @default("Pending") // Pending, InProgress, Approved, Rejected, Cancelled
  totalSteps      Int
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  actions         ApprovalAction[]

  @@index([organizationId])
  @@index([entityType, entityId])
}

model ApprovalAction {
  id                String          @id @default(cuid())
  approvalRequestId String
  approvalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id])
  stepOrder         Int
  userId            String
  user              User            @relation(fields: [userId], references: [id])
  action            String          // Approved, Rejected, Delegated, Comment
  comment           String?
  actionDate        DateTime        @default(now())

  @@index([approvalRequestId])
}

// ============================================
// MULTI-CURRENCY: Exchange Rates & FX Gain/Loss
// ============================================

model ExchangeRate {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  fromCurrency    String
  toCurrency      String
  rate            Float
  effectiveDate   DateTime
  source          String   @default("Manual") // Manual, API
  createdAt       DateTime @default(now())

  @@index([organizationId])
  @@index([organizationId, fromCurrency, toCurrency, effectiveDate])
}

model FxGainLoss {
  id               String        @id @default(cuid())
  organizationId   String
  organization     Organization  @relation(fields: [organizationId], references: [id])
  transactionType  String        // Invoice, Bill, Payment
  transactionId    String
  originalAmount   Float
  originalCurrency String
  convertedAmount  Float
  baseCurrency     String        @default("AUD")
  exchangeRateUsed Float
  gainLoss         Float
  recognizedDate   DateTime
  journalEntryId   String?
  journalEntry     JournalEntry? @relation(fields: [journalEntryId], references: [id])
  createdAt        DateTime      @default(now())

  @@index([organizationId])
  @@index([transactionType, transactionId])
}

// ============================================
// INVENTORY MANAGEMENT
// ============================================

model InventoryItem {
  id                String   @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])
  sku               String
  name              String
  description       String?
  category          String?
  unitOfMeasure     String   @default("each")
  costPrice         Float    @default(0)
  sellingPrice      Float    @default(0)
  taxRateId         String?
  taxRate           TaxRate? @relation(fields: [taxRateId], references: [id])
  accountId         String?
  account           Account? @relation("InventoryAssetAccount", fields: [accountId], references: [id])
  cogsAccountId     String?
  cogsAccount       Account? @relation("InventoryCOGSAccount", fields: [cogsAccountId], references: [id])
  revenueAccountId  String?
  revenueAccount    Account? @relation("InventoryRevenueAccount", fields: [revenueAccountId], references: [id])
  quantityOnHand    Float    @default(0)
  reorderLevel      Float    @default(0)
  reorderQuantity   Float    @default(0)
  isTracked         Boolean  @default(true)
  isActive          Boolean  @default(true)
  supplierId        String?
  supplier          Contact? @relation("InventorySupplier", fields: [supplierId], references: [id])
  location          String?
  barcode           String?
  weight            Float?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  movements         InventoryMovement[]
  stockTakeItems    StockTakeItem[]

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([organizationId, category])
  @@index([organizationId, isActive])
}

model InventoryMovement {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  type            String   // Purchase, Sale, Adjustment, Transfer, WriteOff, Return
  quantity        Float    // positive for in, negative for out
  unitCost        Float    @default(0)
  totalCost       Float    @default(0)
  reference       String?
  referenceType   String?  // Invoice, Bill, Manual
  referenceId     String?
  date            DateTime
  notes           String?
  createdAt       DateTime @default(now())

  @@index([organizationId])
  @@index([inventoryItemId])
  @@index([organizationId, date])
  @@index([referenceType, referenceId])
}

model StockTake {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  date           DateTime
  status         String   @default("Draft") // Draft, InProgress, Completed, Cancelled
  notes          String?
  completedById  String?
  completedBy    User?    @relation("StockTakeCompletedBy", fields: [completedById], references: [id])
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items          StockTakeItem[]

  @@index([organizationId])
  @@index([organizationId, status])
}

model StockTakeItem {
  id               String        @id @default(cuid())
  stockTakeId      String
  stockTake        StockTake     @relation(fields: [stockTakeId], references: [id], onDelete: Cascade)
  inventoryItemId  String
  inventoryItem    InventoryItem @relation(fields: [inventoryItemId], references: [id])
  expectedQuantity Float         @default(0)
  countedQuantity  Float         @default(0)
  variance         Float         @default(0)
  varianceCost     Float         @default(0)
  adjusted         Boolean       @default(false)

  @@index([stockTakeId])
  @@index([inventoryItemId])
}

// ============================================
// PROJECT MANAGEMENT & COSTING
// ============================================

model Project {
  id               String    @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  name             String
  code             String
  description      String?
  clientId         String?
  client           Contact?  @relation("ProjectClient", fields: [clientId], references: [id])
  status           String    @default("Planning") // Planning, Active, OnHold, Completed, Cancelled
  startDate        DateTime?
  endDate          DateTime?
  budgetAmount     Float?
  budgetHours      Float?
  estimatedRevenue Float?
  projectType      String    @default("FixedPrice") // FixedPrice, TimeAndMaterials, Internal, RD
  billingMethod    String    @default("Fixed") // Hourly, Fixed, Milestone, NonBillable
  hourlyRate       Float?
  managerId        String?
  manager          User?     @relation("ProjectManager", fields: [managerId], references: [id])
  isRdProject      Boolean   @default(false)
  rdProjectId      String?
  rdProject        RdProject? @relation("ProjectRdProject", fields: [rdProjectId], references: [id])
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tasks            ProjectTask[]
  timeEntries      TimeEntry[]
  expenses         ProjectExpense[]
  milestones       ProjectMilestone[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, projectType])
}

model ProjectTask {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  assigneeId     String?
  assignee       User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  status         String    @default("Todo") // Todo, InProgress, Review, Done
  estimatedHours Float?
  budgetAmount   Float?
  startDate      DateTime?
  dueDate        DateTime?
  completedDate  DateTime?
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  timeEntries    TimeEntry[]

  @@index([projectId])
  @@index([projectId, status])
}

model TimeEntry {
  id              String    @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id])
  taskId          String?
  task            ProjectTask? @relation(fields: [taskId], references: [id])
  userId          String
  user            User      @relation("TimeEntryUser", fields: [userId], references: [id])
  date            DateTime
  hours           Float
  description     String?
  billable        Boolean   @default(true)
  billed          Boolean   @default(false)
  invoiceId       String?
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id])
  hourlyRate      Float?
  amount          Float?
  approvalStatus  String    @default("Pending") // Pending, Approved, Rejected
  approvedById    String?
  approvedBy      User?     @relation("TimeEntryApprover", fields: [approvedById], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@index([userId])
  @@index([projectId, billable, billed])
}

model ProjectExpense {
  id              String    @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id])
  description     String
  amount          Float
  date            DateTime
  category        String?
  billable        Boolean   @default(true)
  billed          Boolean   @default(false)
  invoiceId       String?
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id])
  receiptUrl      String?
  approvalStatus  String    @default("Pending") // Pending, Approved, Rejected
  approvedById    String?
  approvedBy      User?     @relation("ProjectExpenseApprover", fields: [approvedById], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@index([projectId, billable, billed])
}

model ProjectMilestone {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  amount      Float     @default(0)
  dueDate     DateTime?
  status      String    @default("Pending") // Pending, Invoiced, Paid
  invoiceId   String?
  invoice     Invoice?  @relation(fields: [invoiceId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
}

// ============================================
// DOCUMENT MANAGEMENT
// ============================================

model Document {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  fileName       String
  fileSize       Int      @default(0)
  mimeType       String?
  storageKey     String?
  entityType     String?  // Invoice, Bill, Expense, Contact, Project, Asset, Employee, General
  entityId       String?
  uploadedById   String?
  uploadedBy     User?    @relation("DocumentUploader", fields: [uploadedById], references: [id])
  description    String?
  tags           String?
  createdAt      DateTime @default(now())

  projectRequirements ProjectRequirement[]

  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([organizationId, entityType])
}

// ============================================
// BANK FEEDS
// ============================================

model BankFeed {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  bankName       String
  accountNumber  String
  accountName    String
  status         String   @default("Active") // Active, Paused, Disconnected
  lastSyncAt     DateTime?
  connectionRef  String?
  feedType       String   @default("Direct") // Direct, FileImport
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions   BankFeedTransaction[]

  @@index([organizationId])
  @@index([organizationId, status])
}

model BankFeedTransaction {
  id                    String           @id @default(cuid())
  bankFeedId            String
  bankFeed              BankFeed         @relation(fields: [bankFeedId], references: [id])
  externalId            String
  date                  DateTime
  amount                Float
  description           String
  reference             String?
  category              String?
  status                String           @default("Pending") // Pending, Matched, Created, Ignored
  matchedTransactionId  String?          @unique
  matchedTransaction    BankTransaction? @relation(fields: [matchedTransactionId], references: [id])
  createdAt             DateTime         @default(now())

  @@index([bankFeedId])
  @@index([bankFeedId, status])
  @@index([externalId])
}

// ============================================
// DATA MIGRATION ENGINE
// ============================================

model MigrationJob {
  id                  String    @id @default(cuid())
  organizationId      String
  name                String
  sourceSystem        String    // Xero, MYOB, QuickBooks, CSV, Manual
  status              String    @default("Pending") // Pending, Validating, Importing, Transforming, Reconciling, PendingReview, Approved, Rejected, RolledBack, Completed
  startedAt           DateTime?
  completedAt         DateTime?
  startedById         String
  approvedById        String?
  approvedAt          DateTime?
  totalRecords        Int       @default(0)
  importedRecords     Int       @default(0)
  failedRecords       Int       @default(0)
  warningRecords      Int       @default(0)
  skippedRecords      Int       @default(0)
  rollbackAvailable   Boolean   @default(true)
  rollbackDeadline    DateTime?
  sourceDataSnapshot  String?   // JSON blob path/ref for original data
  notes               String?
  errorLog            String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization        Organization @relation(fields: [organizationId], references: [id])
  startedBy           User         @relation("MigrationJobStartedBy", fields: [startedById], references: [id])
  approvedBy          User?        @relation("MigrationJobApprovedBy", fields: [approvedById], references: [id])
  mappings            MigrationMapping[]
  rules               MigrationRule[]
  reconciliations     MigrationReconciliation[]
  journalEntries      MigrationJournalEntry[]
  auditLogs           MigrationAuditLog[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([startedById])
}

model MigrationMapping {
  id               String    @id @default(cuid())
  migrationJobId   String
  entityType       String    // Account, Contact, Invoice, Bill, Payment, BankTransaction, Employee, Payslip, TaxRate, FixedAsset, InventoryItem, JournalEntry, Project
  sourceId         String
  sourceCode       String?
  sourceName       String?
  sourceData       String?   // JSON of original record
  targetId         String?   // Filled after import
  targetEntityType String?
  status           String    @default("Pending") // Pending, Mapped, Created, Skipped, Failed, Conflict
  mappingNotes     String?
  transformLog     String?   // JSON describing what was changed/recategorized
  requiresReview   Boolean   @default(false)
  reviewedById     String?
  reviewedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  migrationJob     MigrationJob @relation(fields: [migrationJobId], references: [id], onDelete: Cascade)
  reviewedBy       User?        @relation("MigrationMappingReviewer", fields: [reviewedById], references: [id])

  @@index([migrationJobId])
  @@index([migrationJobId, entityType])
  @@index([migrationJobId, status])
  @@index([sourceId])
}

model MigrationRule {
  id             String   @id @default(cuid())
  migrationJobId String
  entityType     String
  sourceField    String
  sourceValue    String
  targetField    String
  targetValue    String
  ruleType       String   // DirectMap, Transform, Merge, Split, Default, Skip, CategoryChange
  description    String?
  priority       Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  migrationJob   MigrationJob @relation(fields: [migrationJobId], references: [id], onDelete: Cascade)

  @@index([migrationJobId])
  @@index([migrationJobId, entityType])
}

model MigrationReconciliation {
  id                 String    @id @default(cuid())
  migrationJobId     String
  entityType         String
  sourceTotal        Float
  importedTotal      Float
  variance           Float
  variancePercentage Float
  status             String    @default("Pending") // Pending, Matched, Variance, Reviewed
  reconciledById     String?
  reconciledAt       DateTime?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  migrationJob       MigrationJob @relation(fields: [migrationJobId], references: [id], onDelete: Cascade)
  reconciledBy       User?        @relation("MigrationReconciler", fields: [reconciledById], references: [id])

  @@index([migrationJobId])
  @@index([migrationJobId, entityType])
}

model MigrationJournalEntry {
  id              String   @id @default(cuid())
  migrationJobId  String
  journalEntryId  String
  description     String?
  entryType       String   // OpeningBalance, DataTransfer, Adjustment, Reconciliation, Rollback
  sourceReference String?
  amount          Float    @default(0)
  createdAt       DateTime @default(now())

  migrationJob    MigrationJob @relation(fields: [migrationJobId], references: [id], onDelete: Cascade)
  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id])

  @@index([migrationJobId])
  @@index([journalEntryId])
}

model MigrationAuditLog {
  id             String   @id @default(cuid())
  migrationJobId String
  timestamp      DateTime @default(now())
  action         String   // RecordImported, RecordTransformed, RecordSkipped, RecordFailed, MappingCreated, RuleApplied, ReconciliationRun, ValidationError, UserApproval, Rollback
  entityType     String?
  entityId       String?
  sourceData     String?
  targetData     String?
  details        String?
  userId         String?
  createdAt      DateTime @default(now())

  migrationJob   MigrationJob @relation(fields: [migrationJobId], references: [id], onDelete: Cascade)
  user           User?        @relation("MigrationAuditLogUser", fields: [userId], references: [id])

  @@index([migrationJobId])
  @@index([migrationJobId, action])
  @@index([migrationJobId, entityType])
  @@index([userId])
}

// ============================================
// SPECIALIST MARKETPLACE
// ============================================

model MarketplaceProvider {
  id                  String   @id @default(cuid())
  name                String
  businessName        String?
  abn                 String?
  email               String
  phone               String?
  website             String?
  description         String?
  category            String   // Consultant, Researcher, Financier, FacilityProvider, PlantHire, RealEstateAgent, Tradesperson, TaxAgent, TechnicalProfessional, Laborer, LabService, EquipmentLeasing, Other
  subcategories       String?  // comma-separated
  qualifications      String?
  insuranceCoverage   String?
  insuranceExpiry     DateTime?
  location            String?
  serviceArea         String?  // e.g. "NSW,VIC,QLD"
  hourlyRate          Float?
  dailyRate           Float?
  minimumEngagement   String?
  leadTimeDays        Int?
  rating              Float    @default(0)
  reviewCount         Int      @default(0)
  verified            Boolean  @default(false)
  verifiedAt          DateTime?
  status              String   @default("Pending") // Active, Pending, Suspended, Inactive
  profileCompleteness Int      @default(0)
  availableFrom       DateTime?
  portfolioUrl        String?
  linkedInUrl         String?
  termsAccepted       Boolean  @default(false)
  termsAcceptedAt     DateTime?
  preferredPayment    String?  // Standard, QuarterlyFinancing, Milestone
  bankBSB             String?
  bankAccountNumber   String?
  bankAccountName     String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  capabilities        ProviderCapability[]
  bids                MarketplaceBid[]
  contracts           MarketplaceContract[]
  contractInvoices    ContractInvoice[]
  reviews             ProviderReview[]
  quarterlyFinancing  QuarterlyFinancingRequest[]

  @@index([category])
  @@index([status])
  @@index([location])
  @@index([rating])
  @@index([category, status])
}

model ProviderCapability {
  id                 String   @id @default(cuid())
  providerId         String
  provider           MarketplaceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  capabilityType     String   // Equipment, Skill, Certification, Facility, Service
  name               String
  description        String?
  details            String?  // JSON for flexible data like equipment specs
  verificationStatus String   @default("Pending") // Pending, Verified, Expired

  @@index([providerId])
  @@index([capabilityType])
  @@index([providerId, capabilityType])
}

model ProjectRequirement {
  id               String   @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  rdProjectId      String?
  rdProject        RdProject? @relation(fields: [rdProjectId], references: [id])
  projectName      String
  description      String?
  status           String   @default("Draft") // Draft, Published, InMarket, Fulfilled, Cancelled
  extractedFrom    String?  // Manual, DesignDocument, ProjectPlan
  sourceDocumentId String?
  sourceDocument   Document? @relation(fields: [sourceDocumentId], references: [id])
  createdById      String
  createdBy        User     @relation("RequirementCreatedBy", fields: [createdById], references: [id])
  approvedById     String?
  approvedBy       User?    @relation("RequirementApprovedBy", fields: [approvedById], references: [id])
  approvedAt       DateTime?
  totalBudget      Float?
  currency         String   @default("AUD")
  startDate        DateTime?
  endDate          DateTime?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items            RequirementItem[]
  listings         MarketplaceListing[]
  suggestions      RequirementSuggestion[]

  @@index([organizationId])
  @@index([rdProjectId])
  @@index([status])
  @@index([organizationId, status])
}

model RequirementItem {
  id                String   @id @default(cuid())
  requirementId     String
  requirement       ProjectRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  category          String   // Researcher, Equipment, Facility, Consultant, TaxAgent, Laborer, Technical, Trade, Other
  quantity          Int      @default(1)
  unitType          String?  // Hours, Days, Weeks, Months, Units
  duration          String?  // e.g. "12 weeks"
  frequencyDescription String? // e.g. "weekly"
  requiredSkills    String?  // comma-separated
  requiredEquipment String?  // comma-separated
  estimatedBudget   Float?
  suggestedProviders String? // JSON array of provider names/types
  alternativeOptions String? // JSON describing alternatives like lease vs hire
  status            String   @default("Draft") // Draft, Approved, InMarket, Assigned, Completed, Cancelled
  priority          String   @default("Medium") // High, Medium, Low
  sortOrder         Int      @default(0)

  listings          MarketplaceListing[]

  @@index([requirementId])
  @@index([category])
  @@index([status])
}

model MarketplaceListing {
  id                      String   @id @default(cuid())
  organizationId          String
  organization            Organization @relation(fields: [organizationId], references: [id])
  requirementId           String?
  requirement             ProjectRequirement? @relation(fields: [requirementId], references: [id])
  requirementItemId       String?
  requirementItem         RequirementItem? @relation(fields: [requirementItemId], references: [id])
  title                   String
  description             String?
  category                String?
  budget                  Float?
  budgetType              String?  // Fixed, Hourly, Daily, Weekly
  duration                String?
  location                String?
  remoteOk                Boolean  @default(false)
  startDate               DateTime?
  endDate                 DateTime?
  status                  String   @default("Open") // Open, Reviewing, Assigned, InProgress, Completed, Cancelled
  visibility              String   @default("Public") // Public, Invited
  paymentTerms            String?  // OnCompletion, Milestone, Monthly, QuarterlyFinancing
  serviceAgreementAccepted Boolean @default(false)
  viewCount               Int      @default(0)
  responseCount           Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  bids                    MarketplaceBid[]
  contracts               MarketplaceContract[]

  @@index([organizationId])
  @@index([status])
  @@index([category])
  @@index([organizationId, status])
}

model MarketplaceBid {
  id                String   @id @default(cuid())
  listingId         String
  listing           MarketplaceListing @relation(fields: [listingId], references: [id])
  providerId        String
  provider          MarketplaceProvider @relation(fields: [providerId], references: [id])
  bidType           String   // Offer, AcceptFixed, CounterOffer
  amount            Float
  currency          String   @default("AUD")
  rateType          String?  // Fixed, Hourly, Daily, Weekly
  proposedStartDate DateTime?
  proposedEndDate   DateTime?
  proposalDescription String?
  includedServices  String?  // what's included
  exclusions        String?  // what's not included
  paymentPreference String?  // Standard, QuarterlyFinancing, Milestone
  status            String   @default("Submitted") // Submitted, Shortlisted, Accepted, Rejected, Withdrawn
  submittedAt       DateTime @default(now())
  respondedAt       DateTime?
  respondedById     String?
  respondedBy       User?    @relation("BidRespondedBy", fields: [respondedById], references: [id])
  notes             String?

  contracts         MarketplaceContract[]

  @@index([listingId])
  @@index([providerId])
  @@index([status])
  @@index([listingId, status])
}

model MarketplaceContract {
  id                    String   @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id])
  listingId             String
  listing               MarketplaceListing @relation(fields: [listingId], references: [id])
  providerId            String
  provider              MarketplaceProvider @relation(fields: [providerId], references: [id])
  bidId                 String?
  bid                   MarketplaceBid? @relation(fields: [bidId], references: [id])
  contractNumber        String   @unique
  title                 String
  description           String?
  agreedAmount          Float
  paymentSchedule       String?  // JSON of milestones/dates
  paymentTerms          String?
  status                String   @default("Draft") // Draft, Active, OnHold, Completed, Terminated, Disputed
  startDate             DateTime?
  endDate               DateTime?
  serviceAgreementUrl   String?
  deliverables          String?  // JSON
  acceptedByProvider    Boolean  @default(false)
  acceptedByProviderAt  DateTime?
  acceptedByClient      Boolean  @default(false)
  acceptedByClientAt    DateTime?
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  milestones            ContractMilestone[]
  invoices              ContractInvoice[]
  reviews               ProviderReview[]
  quarterlyFinancing    QuarterlyFinancingRequest[]

  @@index([organizationId])
  @@index([providerId])
  @@index([status])
  @@index([contractNumber])
  @@index([organizationId, status])
}

model ContractMilestone {
  id                    String   @id @default(cuid())
  contractId            String
  contract              MarketplaceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  name                  String
  description           String?
  amount                Float
  dueDate               DateTime?
  status                String   @default("Pending") // Pending, Submitted, Approved, Paid, Disputed
  deliverableDescription String?
  submittedAt           DateTime?
  approvedById          String?
  approvedBy            User?    @relation("MilestoneApprovedBy", fields: [approvedById], references: [id])
  approvedAt            DateTime?
  invoiceId             String?
  invoice               Invoice? @relation(fields: [invoiceId], references: [id])
  paymentId             String?
  payment               Payment? @relation(fields: [paymentId], references: [id])

  contractInvoices      ContractInvoice[]

  @@index([contractId])
  @@index([status])
}

model ContractInvoice {
  id                        String   @id @default(cuid())
  contractId                String
  contract                  MarketplaceContract @relation(fields: [contractId], references: [id])
  milestoneId               String?
  milestone                 ContractMilestone? @relation(fields: [milestoneId], references: [id])
  providerId                String
  provider                  MarketplaceProvider @relation(fields: [providerId], references: [id])
  organizationId            String
  organization              Organization @relation(fields: [organizationId], references: [id])
  invoiceNumber             String
  amount                    Float
  gstAmount                 Float
  totalAmount               Float
  description               String?
  status                    String   @default("Draft") // Draft, Submitted, Approved, Paid, Rejected, Disputed
  submittedAt               DateTime?
  approvedById              String?
  approvedBy                User?    @relation("ContractInvoiceApprovedBy", fields: [approvedById], references: [id])
  approvedAt                DateTime?
  paidAt                    DateTime?
  paymentMethod             String?  // Standard, QuarterlyFinancing
  quarterlyFinancingApproved Boolean?
  notes                     String?
  createdAt                 DateTime @default(now())

  @@index([contractId])
  @@index([providerId])
  @@index([organizationId])
  @@index([status])
}

model ProviderReview {
  id                  String   @id @default(cuid())
  contractId          String
  contract            MarketplaceContract @relation(fields: [contractId], references: [id])
  providerId          String
  provider            MarketplaceProvider @relation(fields: [providerId], references: [id])
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id])
  reviewerId          String
  reviewer            User     @relation("ProviderReviewer", fields: [reviewerId], references: [id])
  rating              Int      // 1-5
  qualityRating       Int?
  timelinessRating    Int?
  communicationRating Int?
  valueRating         Int?
  comment             String?
  createdAt           DateTime @default(now())

  @@index([providerId])
  @@index([contractId])
  @@index([providerId, rating])
}

model RequirementSuggestion {
  id                     String   @id @default(cuid())
  requirementId          String
  requirement            ProjectRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  suggestedByAI          Boolean  @default(true)
  itemTitle              String
  itemDescription        String?
  category               String?
  quantity               Int?
  unitType               String?
  duration               String?
  estimatedCost          Float?
  rationale              String?
  alternativeDescription String?
  confidence             Float?   // 0-1
  accepted               Boolean?
  acceptedById           String?
  acceptedBy             User?    @relation("SuggestionAcceptedBy", fields: [acceptedById], references: [id])
  acceptedAt             DateTime?

  @@index([requirementId])
  @@index([requirementId, accepted])
}

model QuarterlyFinancingRequest {
  id               String   @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  contractId       String
  contract         MarketplaceContract @relation(fields: [contractId], references: [id])
  providerId       String
  provider         MarketplaceProvider @relation(fields: [providerId], references: [id])
  totalAmount      Float
  quarterlyAmount  Float
  numberOfQuarters Int
  startQuarter     String   // e.g. "Q1 2026"
  status           String   @default("Requested") // Requested, Approved, Active, Completed, Defaulted
  approvedAt       DateTime?
  interestRate     Float    @default(0)
  notes            String?

  @@index([organizationId])
  @@index([contractId])
  @@index([status])
}

// ============================================
// QUOTES
// ============================================

model Quote {
  id                  String    @id @default(cuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id])
  quoteNumber         String
  contactId           String
  contact             Contact   @relation(fields: [contactId], references: [id])
  issueDate           DateTime
  expiryDate          DateTime
  reference           String?
  status              String    @default("Draft") // Draft, Sent, Accepted, Declined, Expired, Converted
  subtotal            Float     @default(0)
  taxTotal            Float     @default(0)
  total               Float     @default(0)
  notes               String?
  terms               String?
  convertedInvoiceId  String?
  convertedInvoice    Invoice?  @relation("QuoteConvertedInvoice", fields: [convertedInvoiceId], references: [id])
  acceptedAt          DateTime?
  acceptedByName      String?
  acceptedByEmail     String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  lines               QuoteLine[]

  @@unique([organizationId, quoteNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([contactId])
}

model QuoteLine {
  id          String   @id @default(cuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description String
  quantity    Float    @default(1)
  unitPrice   Float
  taxRateId   String?
  taxRate     TaxRate? @relation(fields: [taxRateId], references: [id])
  taxAmount   Float    @default(0)
  lineAmount  Float
  accountId   String?
  account     Account? @relation(fields: [accountId], references: [id])
  sortOrder   Int      @default(0)

  @@index([quoteId])
}

// ============================================
// PERIOD LOCKING & YEAR-END
// ============================================

model LockedPeriod {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  periodStart     DateTime
  periodEnd       DateTime
  lockedAt        DateTime @default(now())
  lockedById      String
  lockedBy        User     @relation("LockedByUser", fields: [lockedById], references: [id])
  reason          String?
  status          String   @default("Locked") // Locked, Unlocked

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, periodStart, periodEnd])
}

model YearEndClose {
  id                       String        @id @default(cuid())
  organizationId           String
  organization             Organization  @relation(fields: [organizationId], references: [id])
  financialYear            String        // e.g. "2025-26"
  closeDate                DateTime      @default(now())
  status                   String        @default("InProgress") // InProgress, Completed, Reversed
  retainedEarningsEntryId  String?
  retainedEarningsEntry    JournalEntry? @relation("RetainedEarningsEntry", fields: [retainedEarningsEntryId], references: [id])
  closedById               String
  closedBy                 User          @relation("ClosedByUser", fields: [closedById], references: [id])
  notes                    String?
  createdAt                DateTime      @default(now())

  @@index([organizationId])
  @@index([organizationId, financialYear])
}

// ============================================
// RECURRING BILLS
// ============================================

model RecurringBill {
  id                String    @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])
  contactId         String
  contact           Contact   @relation(fields: [contactId], references: [id])
  frequency         String    // Weekly, Fortnightly, Monthly, Quarterly, Annually
  nextDate          DateTime
  endDate           DateTime?
  accountId         String
  account           Account   @relation(fields: [accountId], references: [id])
  description       String
  amount            Float
  taxRateId         String?
  taxRate           TaxRate?  @relation(fields: [taxRateId], references: [id])
  taxAmount         Float     @default(0)
  totalAmount       Float
  isActive          Boolean   @default(true)
  lastGeneratedDate DateTime?
  generatedCount    Int       @default(0)
  notes             String?

  @@index([organizationId])
  @@index([organizationId, isActive])
}

// ============================================
// LOANS & LOAN PAYMENTS
// ============================================

model Loan {
  id                        String    @id @default(cuid())
  organizationId            String
  organization              Organization @relation(fields: [organizationId], references: [id])
  name                      String
  lender                    String
  lenderContactId           String?
  lenderContact             Contact?  @relation("LoanLenderContact", fields: [lenderContactId], references: [id])
  loanType                  String    // BusinessLoan, CreditLine, Mortgage, Equipment, Vehicle, Other
  principalAmount           Float
  interestRate              Float
  interestType              String    @default("Fixed") // Fixed, Variable
  termMonths                Int
  startDate                 DateTime
  maturityDate              DateTime
  monthlyPayment            Float
  currentBalance            Float
  liabilityAccountId        String
  liabilityAccount          Account   @relation("LoanLiabilityAccount", fields: [liabilityAccountId], references: [id])
  interestExpenseAccountId  String
  interestExpenseAccount    Account   @relation("LoanInterestExpenseAccount", fields: [interestExpenseAccountId], references: [id])
  status                    String    @default("Active") // Active, PaidOff, Defaulted, Refinanced
  notes                     String?

  payments                  LoanPayment[]

  @@index([organizationId])
  @@index([organizationId, status])
}

model LoanPayment {
  id              String        @id @default(cuid())
  loanId          String
  loan            Loan          @relation(fields: [loanId], references: [id])
  date            DateTime
  principalAmount Float
  interestAmount  Float
  totalAmount     Float
  balance         Float         // remaining balance
  journalEntryId  String?
  journalEntry    JournalEntry? @relation(fields: [journalEntryId], references: [id])
  notes           String?

  @@index([loanId])
  @@index([loanId, date])
}

// ============================================
// DIVIDENDS
// ============================================

model Dividend {
  id                    String        @id @default(cuid())
  organizationId        String
  organization          Organization  @relation(fields: [organizationId], references: [id])
  declarationDate       DateTime
  recordDate            DateTime
  paymentDate           DateTime
  amountPerShare        Float
  totalAmount           Float
  frankingPercentage    Float         @default(0) // Australian franking credits
  frankingCredits       Float         @default(0)
  status                String        @default("Declared") // Declared, Paid, Cancelled
  journalEntryId        String?
  journalEntry          JournalEntry? @relation(fields: [journalEntryId], references: [id])
  notes                 String?

  @@index([organizationId])
  @@index([organizationId, status])
}

// ============================================
// COST CENTERS
// ============================================

model CostCenter {
  id              String    @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  code            String
  name            String
  description     String?
  type            String    @default("Department") // Department, Division, Branch, Project, Location
  parentId        String?
  parent          CostCenter?  @relation("CostCenterHierarchy", fields: [parentId], references: [id])
  children        CostCenter[] @relation("CostCenterHierarchy")
  managerId       String?
  manager         User?     @relation("CostCenterManager", fields: [managerId], references: [id])
  isActive        Boolean   @default(true)

  allocations     CostCenterAllocation[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([parentId])
}

model CostCenterAllocation {
  id            String     @id @default(cuid())
  journalLineId String
  journalLine   JournalLine @relation(fields: [journalLineId], references: [id])
  costCenterId  String
  costCenter    CostCenter  @relation(fields: [costCenterId], references: [id])
  percentage    Float
  amount        Float

  @@index([journalLineId])
  @@index([costCenterId])
}

// ============================================
// PAYMENT REMINDERS
// ============================================

model PaymentReminder {
  id              String    @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  invoiceId       String
  invoice         Invoice   @relation(fields: [invoiceId], references: [id])
  scheduleType    String    // BeforeDue, OnDue, AfterDue
  daysOffset      Int
  status          String    @default("Scheduled") // Scheduled, Sent, Cancelled
  scheduledDate   DateTime
  sentAt          DateTime?
  emailTo         String?
  emailSubject    String?
  templateType    String    @default("Reminder") // Reminder, Overdue, Final

  @@index([organizationId])
  @@index([invoiceId])
  @@index([status, scheduledDate])
}

// ============================================
// COMPLIANCE DEADLINES
// ============================================

model ComplianceDeadline {
  id              String    @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  title           String
  description     String?
  category        String    // BAS, STP, SuperGuarantee, PayrollTax, IncomeTax, FBT, WorkersComp, AnnualReturn, RDTaxIncentive, Other
  dueDate         DateTime
  frequency       String    @default("Quarterly") // OneOff, Monthly, Quarterly, Annually
  status          String    @default("Upcoming") // Upcoming, Due, Overdue, Completed, NotApplicable
  completedAt     DateTime?
  completedById   String?
  completedBy     User?     @relation("DeadlineCompletedBy", fields: [completedById], references: [id])
  notes           String?
  reminderDays    Int       @default(14)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, category])
  @@index([dueDate])
}

// ============================================
// CUSTOMER PORTAL
// ============================================

model CustomerPortalToken {
  id              String    @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  contactId       String
  contact         Contact   @relation(fields: [contactId], references: [id])
  token           String    @unique
  expiresAt       DateTime
  isActive        Boolean   @default(true)
  lastAccessedAt  DateTime?
  createdAt       DateTime  @default(now())

  @@index([organizationId])
  @@index([contactId])
  @@index([token])
}

// ============================================
// ONLINE PAYMENTS
// ============================================

model OnlinePayment {
  id              String    @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  invoiceId       String
  invoice         Invoice   @relation(fields: [invoiceId], references: [id])
  gateway         String    // Stripe, PayPal, BankTransfer
  transactionId   String?
  amount          Float
  currency        String    @default("AUD")
  status          String    @default("Pending") // Pending, Completed, Failed, Refunded
  paidAt          DateTime?
  gatewayResponse String?   // JSON response from gateway
  payerEmail      String?
  payerName       String?

  @@index([organizationId])
  @@index([invoiceId])
  @@index([gateway, transactionId])
}

// ============================================
// REPORT TEMPLATES
// ============================================

model ReportTemplate {
  id                String    @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])
  name              String
  description       String?
  baseReport        String    // ProfitLoss, BalanceSheet, TrialBalance, CashFlow, Custom
  columns           String?   // JSON array of column configs
  filters           String?   // JSON
  groupBy           String?
  dateRange         String?
  includeComparison Boolean   @default(false)
  createdById       String
  createdBy         User      @relation("ReportTemplateCreator", fields: [createdById], references: [id])
  isPublic          Boolean   @default(false)

  @@index([organizationId])
  @@index([organizationId, baseReport])
}
